{
  "name": "csslit-vscode",
  "displayName": "csslit",
  "version": "0.0.5",
  "private": true,
  "description": "VS Code support for csslit.",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/csslit/csslit.git",
    "directory": "vscode"
  },
  "publisher": "csslit",
  "main": "./dist/extension.js",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "cson-parser": "^4.0.9",
    "oniguruma-parser": "^0.12.2",
    "tm-grammars": "^1.31.15",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.5",
    "vscode-css": "git+https://github.com/torresgol10/vscode-css.git#e763075e78c4cfecc0bb5270e920c78776014f96",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.csslit.css",
        "path": "./dist/syntaxes/csslit-css.tmLanguage.json"
      },
      {
        "scopeName": "csslit.javascript.injection",
        "path": "./dist/syntaxes/csslit-javascript.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.astro",
          "source.svelte",
          "text.html.basic",
          "text.html.vue"
        ],
        "embeddedLanguages": {
          "meta.embedded.inline.csslit": "css"
        }
      },
      {
        "scopeName": "csslit.javascript.holes.injection",
        "path": "./dist/syntaxes/csslit-javascript-holes.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.astro",
          "source.svelte",
          "text.html.basic",
          "text.html.vue"
        ],
        "embeddedLanguages": {
          "meta.template.expression.js": "javascript"
        }
      },
      {
        "scopeName": "csslit.javascriptreact.injection",
        "path": "./dist/syntaxes/csslit-javascriptreact.tmLanguage.json",
        "injectTo": [
          "source.js.jsx",
          "source.astro",
          "source.svelte",
          "text.html.vue"
        ],
        "embeddedLanguages": {
          "meta.embedded.inline.csslit": "css"
        }
      },
      {
        "scopeName": "csslit.javascriptreact.holes.injection",
        "path": "./dist/syntaxes/csslit-javascriptreact-holes.tmLanguage.json",
        "injectTo": [
          "source.js.jsx",
          "source.astro",
          "source.svelte",
          "text.html.vue"
        ],
        "embeddedLanguages": {
          "meta.template.expression.js.jsx": "javascriptreact"
        }
      },
      {
        "scopeName": "csslit.typescript.injection",
        "path": "./dist/syntaxes/csslit-typescript.tmLanguage.json",
        "injectTo": [
          "source.ts",
          "source.astro",
          "source.svelte",
          "source.ts.ng",
          "text.marko",
          "text.html.vue"
        ],
        "embeddedLanguages": {
          "meta.embedded.inline.csslit": "css"
        }
      },
      {
        "scopeName": "csslit.typescript.holes.injection",
        "path": "./dist/syntaxes/csslit-typescript-holes.tmLanguage.json",
        "injectTo": [
          "source.ts",
          "source.astro",
          "source.svelte",
          "source.ts.ng",
          "text.marko",
          "text.html.vue"
        ],
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      },
      {
        "scopeName": "csslit.typescriptreact.injection",
        "path": "./dist/syntaxes/csslit-typescriptreact.tmLanguage.json",
        "injectTo": [
          "source.tsx",
          "source.astro",
          "source.svelte",
          "source.ts.ng",
          "text.html.vue"
        ],
        "embeddedLanguages": {
          "meta.embedded.inline.csslit": "css"
        }
      },
      {
        "scopeName": "csslit.typescriptreact.holes.injection",
        "path": "./dist/syntaxes/csslit-typescriptreact-holes.tmLanguage.json",
        "injectTo": [
          "source.tsx",
          "source.astro",
          "source.svelte",
          "source.ts.ng",
          "text.html.vue"
        ],
        "embeddedLanguages": {
          "meta.template.expression.tsx": "typescriptreact"
        }
      },
      {
        "scopeName": "csslit.mdx.injection",
        "path": "./dist/syntaxes/csslit-mdx.tmLanguage.json",
        "injectTo": [
          "source.mdx"
        ],
        "embeddedLanguages": {
          "meta.embedded.inline.csslit": "css"
        }
      },
      {
        "scopeName": "csslit.mdx.holes.injection",
        "path": "./dist/syntaxes/csslit-mdx-holes.tmLanguage.json",
        "injectTo": [
          "source.mdx"
        ],
        "embeddedLanguages": {
          "meta.template.expression.tsx": "typescriptreact"
        }
      },
      {
        "scopeName": "csslit.tsrx.injection",
        "path": "./dist/syntaxes/csslit-tsrx.tmLanguage.json",
        "injectTo": [
          "source.tsrx"
        ],
        "embeddedLanguages": {
          "meta.embedded.inline.csslit": "css"
        }
      },
      {
        "scopeName": "csslit.tsrx.holes.injection",
        "path": "./dist/syntaxes/csslit-tsrx-holes.tmLanguage.json",
        "injectTo": [
          "source.tsrx"
        ],
        "embeddedLanguages": {
          "meta.template.expression.js": "ripple"
        }
      },
      {
        "scopeName": "csslit.angular.injection",
        "path": "./dist/syntaxes/csslit-angular.tmLanguage.json",
        "injectTo": [
          "source.ts.ng",
          "text.html.derivative.ng"
        ],
        "embeddedLanguages": {
          "meta.embedded.inline.csslit": "css"
        }
      },
      {
        "scopeName": "csslit.angular.holes.injection",
        "path": "./dist/syntaxes/csslit-angular-holes.tmLanguage.json",
        "injectTo": [
          "source.ts.ng",
          "text.html.derivative.ng"
        ],
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      }
    ]
  },
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "engines": {
    "vscode": "^1.125.0"
  },
  "vsce": {
    "dependencies": false
  }
}

{
  "name": "@csslit/rust-transformer",
  "version": "0.1.0",
  "description": "Native and WebAssembly transforms used by csslit.",
  "keywords": [
    "css",
    "oxc",
    "transform"
  ],
  "homepage": "https://github.com/csslit/csslit#readme",
  "bugs": "https://github.com/csslit/csslit/issues",
  "license": "MIT",
  "author": "Gabriel Valfridsson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csslit/csslit.git",
    "directory": "packages/rust-transformer"
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.js",
    "webcontainer-fallback.cjs"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@napi-rs/cli": "^3.7.3",
    "@napi-rs/wasm-runtime": "^1.1.6",
    "@tybys/wasm-util": "^0.10.3",
    "vite-plus": "^0.2.0"
  },
  "optionalDependencies": {
    "@csslit/rust-transformer-linux-x64-gnu": "0.1.0",
    "@csslit/rust-transformer-linux-x64-musl": "0.1.0",
    "@csslit/rust-transformer-wasm32-wasi": "0.1.0",
    "@csslit/rust-transformer-win32-x64-msvc": "0.1.0"
  },
  "napi": {
    "binaryName": "csslit-transformer",
    "packageName": "@csslit/rust-transformer",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "wasm32-wasip1-threads"
    ],
    "wasm": {
      "browser": {
        "fs": false
      }
    }
  },
  "engines": {
    "node": ">=24.11.0"
  }
}

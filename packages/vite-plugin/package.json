{
  "name": "@csslit/vite-plugin",
  "version": "0.0.7",
  "description": "Vite plugin for compile-time csslit styles.",
  "keywords": [
    "css",
    "css-in-js",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/csslit/csslit#readme",
  "bugs": "https://github.com/csslit/csslit/issues",
  "license": "MIT",
  "author": "Gabriel Valfridsson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csslit/csslit.git",
    "directory": "packages/vite-plugin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@csslit/transform": "^0.0.7",
    "@jridgewell/gen-mapping": "^0.3.13",
    "@jridgewell/trace-mapping": "^0.3.31",
    "es-module-lexer": "^2.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plus": "^0.2.5"
  },
  "peerDependencies": {
    "vite": "^8.1.5"
  },
  "engines": {
    "node": ">=24.11.0"
  }
}
